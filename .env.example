# Copy to .env (which is gitignored) and fill in real values.
# Loaded by divdprint/settings.py for gunicorn and the manage.py services.

# Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Password for the hidden /shutdown kiosk command (server-side checked).
KIOSK_SHUTDOWN_PASSWORD=

# Password for the hidden /admin kiosk command (wifi config + bash shell).
KIOSK_ADMIN_PASSWORD=
